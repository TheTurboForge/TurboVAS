def run_git(repo_root: Path, args: list[str]) -> str | None:
    try:
        result = subprocess.run(["git", *args], cwd=repo_root, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=True)
    except (OSError, subprocess.CalledProcessError):
        return None
    return result.stdout.strip()


def run_command(command: list[str], cwd: Path, env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, cwd=cwd, env=env, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)


def find_repo_root(start: Path) -> Path:
    git_root = run_git(start, ["rev-parse", "--show-toplevel"])
    if git_root:
        return Path(git_root)
    return start.resolve()


def metadata(repo_root: Path, command: str) -> dict[str, Any]:
    return {
        "command": command,
        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "repo_root": str(repo_root),
        "head": run_git(repo_root, ["rev-parse", "--short", "HEAD"]),
    }


def status_rank(status: str) -> int:
    return STATUSES.index(status)


def aggregate_status(findings: Iterable[dict[str, Any]]) -> str:
    final = "pass"
    for item in findings:
        status = str(item.get("status", "pass"))
        if status not in STATUSES:
            status = "fail"
        if status_rank(status) > status_rank(final):
            final = status
    return final


def make_result(command: str, repo_root: Path, summary: str, findings: list[dict[str, Any]], artifacts: list[str] | None = None) -> dict[str, Any]:
    return {"status": aggregate_status(findings), "summary": summary, "findings": findings, "artifacts": artifacts or [], "metadata": metadata(repo_root, command)}


def finding(status: str, check: str, message: str, path: str | None = None, details: dict[str, Any] | None = None) -> dict[str, Any]:
    item: dict[str, Any] = {"status": status, "check": check, "message": message}
    if path:
        item["path"] = path
    if details:
        item["details"] = details
    return item


def build_env(repo_root: Path) -> dict[str, str]:
    env = dict(os.environ)
    prefix = repo_root / "build" / "prefix"
    pkg_paths = [str(prefix / "lib" / "pkgconfig"), str(prefix / "lib64" / "pkgconfig")]
    current_pkg = env.get("PKG_CONFIG_PATH")
    if current_pkg:
        pkg_paths.append(current_pkg)
    env["PKG_CONFIG_PATH"] = ":".join(pkg_paths)
    env["CMAKE_PREFIX_PATH"] = str(prefix)
    ld_paths = [str(prefix / "lib"), str(prefix / "lib64")]
    current_ld = env.get("LD_LIBRARY_PATH")
    if current_ld:
        ld_paths.append(current_ld)
    env["LD_LIBRARY_PATH"] = ":".join(ld_paths)
    return env


def runtime_dir(repo_root: Path) -> Path:
    configured = os.environ.get("TURBOVAS_RUNTIME_DIR")
    if configured:
        return Path(configured).expanduser().resolve()
    return (repo_root.parent / "TurboVAS-runtime").resolve()


def runtime_env(repo_root: Path) -> dict[str, str]:
    env = build_env(repo_root)
    env.setdefault("COMPOSE_PROJECT_NAME", "turbovas")
    env.setdefault("TURBOVAS_RUNTIME_DIR", str(runtime_dir(repo_root)))
    env.setdefault("TURBOVAS_UID", str(os.getuid()))
    env.setdefault("TURBOVAS_GID", str(os.getgid()))
    env.setdefault("POSTGRES_USER", POSTGRES_DEFAULTS["user"])
    env.setdefault("POSTGRES_PASSWORD", POSTGRES_DEFAULTS["password"])
    env.setdefault("POSTGRES_DB", POSTGRES_DEFAULTS["database"])
    return env


def compose_file(repo_root: Path) -> Path:
    return repo_root / "compose" / "dev.yaml"


def compose_command(repo_root: Path, *args: str) -> list[str]:
    return ["docker", "compose", "-f", str(compose_file(repo_root)), *args]


def ensure_runtime_dirs(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    root = runtime_dir(repo_root)
    for dirname in RUNTIME_DIRS:
        path = root / dirname
        try:
            path.mkdir(parents=True, exist_ok=True)
            probe = path / ".turbovas-write-test"
            probe.write_text("ok\n", encoding="utf-8")
            probe.unlink()
            status = "pass"
            message = f"Runtime directory is writable: {path}"
        except OSError as error:
            status = "fail"
            message = f"Runtime directory is not writable: {path}: {error}"
        findings.append(finding(status, "runtime.dir", message, str(path)))
    return findings


def container_id(repo_root: Path, service: str) -> str | None:
    result = run_command(compose_command(repo_root, "ps", "-q", service), repo_root, env=runtime_env(repo_root))
    if result.returncode == 0 and result.stdout.strip():
        return result.stdout.strip().splitlines()[0]
    return None


def container_running(repo_root: Path, service: str) -> bool:
    cid = container_id(repo_root, service)
    if not cid:
        return False
    result = run_command(["docker", "inspect", "-f", "{{.State.Running}}", cid], repo_root, env=runtime_env(repo_root))
    return result.returncode == 0 and result.stdout.strip() == "true"


def exec_in_service(repo_root: Path, service: str, command: list[str]) -> subprocess.CompletedProcess[str]:
    return run_command(compose_command(repo_root, "exec", "-T", service, *command), repo_root, env=runtime_env(repo_root))


def postgres_user(repo_root: Path) -> str:
    return runtime_env(repo_root).get("POSTGRES_USER", POSTGRES_DEFAULTS["user"])


def postgres_password(repo_root: Path) -> str:
    return runtime_env(repo_root).get("POSTGRES_PASSWORD", POSTGRES_DEFAULTS["password"])


def postgres_database(repo_root: Path) -> str:
    return runtime_env(repo_root).get("POSTGRES_DB", POSTGRES_DEFAULTS["database"])


def sql_identifier(identifier: str) -> str:
    return '"' + identifier.replace('"', '""') + '"'


def sql_literal(value: str) -> str:
    return "'" + value.replace("'", "''") + "'"


def postgres_ready(repo_root: Path) -> subprocess.CompletedProcess[str]:
    return exec_in_service(repo_root, "postgres", ["pg_isready", "-U", postgres_user(repo_root), "-d", postgres_database(repo_root)])


def psql(repo_root: Path, sql: str, database: str | None = None) -> subprocess.CompletedProcess[str]:
    return exec_in_service(
        repo_root,
        "postgres",
        [
            "env",
            f"PGPASSWORD={postgres_password(repo_root)}",
            "psql",
            "-v",
            "ON_ERROR_STOP=1",
            "-U",
            postgres_user(repo_root),
            "-d",
            database or postgres_database(repo_root),
            "-At",
            "-c",
            sql,
        ],
    )


def psql_value(result: subprocess.CompletedProcess[str]) -> str:
    ignored_prefixes = ("WARNING:", "DETAIL:", "HINT:", "NOTICE:")
    for line in reversed(result.stdout.splitlines()):
        clean = line.strip()
        if clean and not clean.startswith(ignored_prefixes):
            return clean
    return ""


def ensure_postgres_collation(repo_root: Path, refresh_empty: bool = True) -> dict[str, Any]:
    result = psql(repo_root, "SELECT datcollversion || '|' || pg_database_collation_actual_version(oid) FROM pg_database WHERE datname = current_database();")
    if result.returncode != 0:
        return finding("fail", "postgres.collation", f"Collation version check exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-40:]})
    value = psql_value(result)
    if "|" not in value:
        return finding("warn", "postgres.collation", "Could not parse database collation version check.", details={"output_tail": result.stdout.splitlines()[-40:]})
    recorded, actual = value.split("|", 1)
    if recorded == actual:
        return finding("pass", "postgres.collation", f"Database collation version is current: {actual}.", details={"recorded": recorded, "actual": actual})

    count_result = psql(repo_root, "SELECT count(*) FROM pg_class WHERE relkind IN ('r','i','S','v','m') AND relnamespace NOT IN (SELECT oid FROM pg_namespace WHERE nspname LIKE 'pg_%' OR nspname = 'information_schema');")
    if count_result.returncode != 0:
        return finding("fail", "postgres.collation", f"Collation mismatch {recorded} != {actual}; relation-count check failed.", details={"output_tail": count_result.stdout.splitlines()[-40:]})
    relation_count = psql_value(count_result)
    if relation_count == "0" and refresh_empty:
        refresh = psql(repo_root, f"ALTER DATABASE {sql_identifier(postgres_database(repo_root))} REFRESH COLLATION VERSION;")
        return finding("pass" if refresh.returncode == 0 else "fail", "postgres.collation", f"Refreshed empty development database collation version from {recorded} to {actual}.", details={"recorded": recorded, "actual": actual, "relation_count": relation_count, "output_tail": refresh.stdout.splitlines()[-40:]})
    if relation_count == "0":
        return finding("warn", "postgres.collation", f"Database collation version mismatch {recorded} != {actual}; runtime-init can refresh this empty development database.", details={"recorded": recorded, "actual": actual, "relation_count": relation_count})
    return finding("warn", "postgres.collation", f"Database collation version mismatch {recorded} != {actual}; manual review required before refreshing a database with objects.", details={"recorded": recorded, "actual": actual, "relation_count": relation_count})


def pg_gvm_artifacts(repo_root: Path) -> tuple[list[dict[str, Any]], dict[str, Path]]:
    prefix = repo_root / "build" / "prefix"
    extension_dir = prefix / "share" / "postgresql" / "extension"
    library = prefix / "lib" / "postgresql" / PG_GVM_LIBRARY
    sql_files = sorted(extension_dir.glob("pg-gvm--*.sql"))
    artifacts = {
        "extension_dir": extension_dir,
        "control": extension_dir / PG_GVM_CONTROL,
        "library": library,
    }
    findings = [
        finding("pass" if artifacts["control"].is_file() else "fail", "pg-gvm.control", f"{PG_GVM_CONTROL} is available in build/prefix.", str(artifacts["control"].relative_to(repo_root)) if artifacts["control"].exists() else str(artifacts["control"])),
        finding("pass" if library.is_file() else "fail", "pg-gvm.library", f"{PG_GVM_LIBRARY} is available in build/prefix.", str(library.relative_to(repo_root)) if library.exists() else str(library)),
        finding("pass" if sql_files else "fail", "pg-gvm.sql", "pg-gvm extension SQL files are available in build/prefix.", details={"files": [str(path.relative_to(repo_root)) for path in sql_files]}),
    ]
    return findings, artifacts


def copy_pg_gvm_extension(repo_root: Path) -> list[dict[str, Any]]:
    artifact_findings, artifacts = pg_gvm_artifacts(repo_root)
    if aggregate_status(artifact_findings) == "fail":
        return artifact_findings
    extension_dir = artifacts["extension_dir"]
    library = artifacts["library"]
    copy_sql = run_command(
        compose_command(repo_root, "cp", str(extension_dir) + "/.", f"postgres:/usr/share/postgresql/16/extension/"),
        repo_root,
        env=runtime_env(repo_root),
    )
    copy_library = run_command(
        compose_command(repo_root, "cp", str(library), f"postgres:/usr/lib/postgresql/16/lib/{PG_GVM_LIBRARY}"),
        repo_root,
        env=runtime_env(repo_root),
    )
    return [
        *artifact_findings,
        finding("pass" if copy_sql.returncode == 0 else "fail", "pg-gvm.copy.sql", f"Copy pg-gvm SQL/control files exit code {copy_sql.returncode}.", details={"output_tail": copy_sql.stdout.splitlines()[-40:]}),
        finding("pass" if copy_library.returncode == 0 else "fail", "pg-gvm.copy.library", f"Copy pg-gvm shared library exit code {copy_library.returncode}.", details={"output_tail": copy_library.stdout.splitlines()[-40:]}),
    ]


def pg_gvm_extension_status(repo_root: Path) -> dict[str, Any]:
    if not container_running(repo_root, "postgres"):
        return finding("warn", "postgres.pg-gvm", "Postgres is not running; pg-gvm extension status is unavailable.")
    result = psql(repo_root, f"SELECT COALESCE((SELECT extversion FROM pg_extension WHERE extname = '{PG_GVM_EXTENSION}'), 'missing');")
    if result.returncode != 0:
        return finding("fail", "postgres.pg-gvm", f"pg-gvm extension status query exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-40:]})
    version = psql_value(result)
    return finding("pass" if version and version != "missing" else "warn", "postgres.pg-gvm", f"pg-gvm extension is {version}.", details={"version": version})


def component_inventory(repo_root: Path, scope: str | None = None) -> list[dict[str, Any]]:
    scope_path = (repo_root / scope).resolve() if scope else None
    rows: list[dict[str, Any]] = []
    for component in COMPONENTS:
        component_path = repo_root / component.path
        if scope_path and not component_path.resolve().is_relative_to(scope_path):
            continue
        rows.append(
            {
                "name": component.name,
                "path": component.path,
                "role": component.role,
                "exists": component_path.is_dir(),
                "license_files": [{"path": f"{component.path}/{license_file}", "exists": (component_path / license_file).is_file()} for license_file in component.licenses],
                "markers": [{"path": f"{component.path}/{marker}", "exists": (component_path / marker).exists()} for marker in component.markers],
            }
        )
    return rows


def nested_git_dirs(repo_root: Path) -> list[str]:
    components = repo_root / "components"
    if not components.is_dir():
        return []
    return sorted(str(path.relative_to(repo_root)) for path in components.rglob(".git"))


def selected_build_metas(component: str | None = None) -> list[BuildMeta]:
    if component:
        meta = BUILD_META.get(component)
        if not meta:
            raise KeyError(component)
        return [meta]
    return sorted(BUILD_META.values(), key=lambda meta: meta.order)


def pkg_config_version(module: str, env: dict[str, str]) -> str | None:
    result = run_command(["pkg-config", "--modversion", module], Path.cwd(), env=env)
    if result.returncode == 0:
        return result.stdout.strip()
    return None


def tool_version(program: str) -> str | None:
    probes = {
        "node": ["node", "--version"],
        "npm": ["npm", "--version"],
        "python3": ["python3", "--version"],
        "uv": ["uv", "--version"],
    }
    command = probes.get(program)
    if not command or not shutil.which(command[0]):
        return None
    result = run_command(command, Path.cwd())
    if result.returncode == 0:
        return result.stdout.strip()
    return None


def version_tuple(version: str) -> tuple[int, ...]:
    clean = version.strip().lstrip("v")
    parts: list[int] = []
    for piece in clean.split("."):
        number = ""
        for character in piece:
            if character.isdigit():
                number += character
            else:
                break
        if number:
            parts.append(int(number))
        else:
            break
    return tuple(parts)


def command_status(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    branch = run_git(repo_root, ["branch", "--show-current"]) or "(detached or unavailable)"
    head = run_git(repo_root, ["rev-parse", "--short", "HEAD"]) or "unavailable"
    porcelain = run_git(repo_root, ["status", "--short"]) or ""
    upstream = run_git(repo_root, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"])
    findings.append(finding("pass", "git.repository", f"Repository root: {repo_root}"))
    findings.append(finding("pass", "git.head", f"Current branch {branch} at {head}"))
    findings.append(finding("pass" if upstream else "warn", "git.upstream", f"Tracking upstream: {upstream}" if upstream else "No upstream tracking branch is configured."))
    if porcelain:
        findings.append(finding("warn", "git.worktree", "Worktree has uncommitted changes.", details={"changed_files": porcelain.splitlines()}))
    else:
        findings.append(finding("pass", "git.worktree", "Worktree is clean."))
    return make_result("status", repo_root, "Repository status collected.", findings)


def command_inventory(repo_root: Path, scope: str | None = None) -> dict[str, Any]:
